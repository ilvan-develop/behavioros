# BehaviorOS Environment Variables

# Better Auth
BETTER_AUTH_SECRET=your-secret-here-change-in-production
BETTER_AUTH_URL=http://localhost:3000

# OAuth Providers (optional — app works without these)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database (optional — uses memory DB by default)
DATABASE_URL=

# BehaviorOS
BEHAVIOROS_DNA_PATH=./dnas/enterprise-governance.yaml
BEHAVIOROS_PROJECT=behavioros
BEHAVIOROS_LOG_LEVEL=info
