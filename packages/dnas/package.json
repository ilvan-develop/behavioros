{
  "name": "@behavioros/dnas",
  "version": "0.1.0",
  "description": "BehaviorOS DNA Catalog — 13 behavioral patterns for AI agent teams",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "author": "Ilvan Joaquim",
  "license": "MIT",
  "keywords": [
    "behavioros",
    "dna",
    "ai-agents",
    "behavioral-patterns",
    "yaml"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ilvan-develop/behavioros",
    "directory": "packages/dnas"
  },
  "homepage": "https://github.com/ilvan-develop/behavioros",
  "bugs": {
    "url": "https://github.com/ilvan-develop/behavioros/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs",
    "dev": "tsup src/index.ts --format esm,cjs --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@behavioros/schemas": "workspace:*",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@behavioros/core": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "peerDependencies": {}
}
