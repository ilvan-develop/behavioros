{
  "name": "@behavioros/observability-dashboard",
  "version": "0.1.0",
  "description": "Unified observability dashboard for BehaviorOS ecosystem",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@behavioros/core": "workspace:*",
    "@behavioros/schemas": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  }
}
