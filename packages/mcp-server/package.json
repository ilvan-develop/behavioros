{
  "name": "@behavioros/mcp-server",
  "version": "0.2.0",
  "description": "BehaviorOS MCP Server — Model Context Protocol server for BehaviorOS",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "behavioros-mcp": "./dist/server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "Ilvan Joaquim",
  "license": "MIT",
  "keywords": [
    "behavioros",
    "mcp",
    "mcp-server",
    "ai-agents",
    "governance",
    "claude",
    "cursor"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ilvan-develop/behavioros",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/ilvan-develop/behavioros",
  "bugs": {
    "url": "https://github.com/ilvan-develop/behavioros/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/server.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@behavioros/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@behavioros/schemas": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
