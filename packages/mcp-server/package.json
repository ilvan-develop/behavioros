{
  "name": "@behavioros/mcp-server",
  "version": "0.1.0",
  "description": "BehaviorOS MCP Server — Model Context Protocol server for BehaviorOS",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "behavioros-mcp": "./dist/server.js"
  },
  "scripts": {
    "build": "tsup src/server.ts src/index.ts --format esm,cjs",
    "dev": "tsx watch src/server.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@behavioros/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
