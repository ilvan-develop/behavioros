{
  "name": "@behavioros/sdk",
  "version": "1.0.1",
  "description": "BehaviorOS SDK — TypeScript SDK for integrating with AI agent orchestrators",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "Ilvan Joaquim",
  "license": "MIT",
  "keywords": [
    "behavioros",
    "sdk",
    "ai-agents",
    "governance",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ilvan-develop/behavioros",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/ilvan-develop/behavioros",
  "bugs": {
    "url": "https://github.com/ilvan-develop/behavioros/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs",
    "dev": "tsup src/index.ts --dts --format esm,cjs --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "eventemitter3": "^5.0.0",
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@behavioros/core": "workspace:*",
    "@behavioros/schemas": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "peerDependencies": {
    "@behavioros/core": "workspace:*"
  }
}
