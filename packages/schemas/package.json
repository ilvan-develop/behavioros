{
  "name": "@behavioros/schemas",
  "version": "0.2.0",
  "description": "BehaviorOS Schemas — Zod + JSON Schema for BehaviorOS configuration",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "Ilvan Joaquim",
  "license": "MIT",
  "keywords": [
    "behavioros",
    "schemas",
    "zod",
    "ai-agents",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ilvan-develop/behavioros",
    "directory": "packages/schemas"
  },
  "homepage": "https://github.com/ilvan-develop/behavioros",
  "bugs": {
    "url": "https://github.com/ilvan-develop/behavioros/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs",
    "dev": "tsup src/index.ts --dts --format esm,cjs --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^3.24.0",
    "ajv": "^8.17.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
