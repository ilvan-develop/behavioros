{
  "name": "@behavioros/cli",
  "version": "0.1.0",
  "description": "BehaviorOS CLI — Command-line interface for BehaviorOS",
  "bin": {
    "behavioros": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/bin.ts src/index.ts --format esm,cjs",
    "dev": "tsup src/bin.ts src/index.ts --format esm,cjs --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "chalk": "^5.6.0",
    "ora": "^9.4.0",
    "@inquirer/prompts": "^8.5.0",
    "cli-table3": "^0.6.5",
    "cosmiconfig": "^9.0.2",
    "yaml": "^2.7.0",
    "glob": "^11.0.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "peerDependencies": {
    "@behavioros/core": "workspace:*",
    "@behavioros/sdk": "workspace:*"
  }
}
