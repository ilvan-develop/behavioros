{
  "name": "@behavioros/cli",
  "version": "1.0.1",
  "description": "BehaviorOS CLI — Command-line interface for BehaviorOS",
  "bin": {
    "behavioros": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "Ilvan Joaquim",
  "license": "MIT",
  "keywords": [
    "behavioros",
    "cli",
    "ai-agents",
    "governance"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ilvan-develop/behavioros",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/ilvan-develop/behavioros",
  "bugs": {
    "url": "https://github.com/ilvan-develop/behavioros/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup src/bin.ts src/index.ts --format esm,cjs",
    "dev": "tsup src/bin.ts src/index.ts --format esm,cjs --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "chalk": "^5.6.0",
    "ora": "^9.4.0",
    "@inquirer/prompts": "^8.5.0",
    "cli-table3": "^0.6.5",
    "cosmiconfig": "^9.0.2",
    "yaml": "^2.7.0",
    "glob": "^11.0.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@behavioros/core": "workspace:*",
    "@behavioros/schemas": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "peerDependencies": {
    "@behavioros/core": "workspace:*"
  }
}
